{
    "name": "modern-astro-site",
    "type": "module",
    "version": "0.0.11",
    "scripts": {
        "build": "astro build",
        "start:production": "node server.mjs",
        "dev:caddy": "USE_PROXY=true astro dev --host 0.0.0.0 --port 1101",
        "caddy:start": "sudo env $(grep -v '^#' .env.development | grep '^TLS_' | xargs) caddy start --config Caddyfile",
        "caddy:stop": "sudo caddy stop",
        "caddy:reload": "sudo env $(grep -v '^#' .env.development | grep '^TLS_' | xargs) caddy reload --config Caddyfile",
        "dev:https": "npm run caddy:start && npm run dev:caddy",
        "lint": "eslint --ext .js,.jsx,.astro src/",
        "lint:fix": "eslint --fix --ext .js,.jsx,.astro src/"
    },
    "dependencies": {
        "@astrojs/node": "^9.5.5",
        "@astrojs/react": "^4.3.0",
        "@astrojs/tailwind": "^6.0.2",
        "astro": "^5.9.3",
        "compression": "^1.8.1",
        "express": "^5.2.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    },
    "devDependencies": {
        "eslint": "^9.29.0",
        "eslint-plugin-astro": "^1.2.0",
        "eslint-plugin-jsx-a11y": "^6.9.0",
        "eslint-plugin-react": "^7.34.3",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-security": "^3.0.1",
        "eslint-plugin-tailwindcss": "^3.17.2",
        "globals": "^16.2.0"
    }
}
