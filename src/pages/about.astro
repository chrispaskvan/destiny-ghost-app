---
import PolicyLayout from '../layouts/PolicyLayout.astro';
import { SUPPORT_EMAIL } from '../config/site';
---

<PolicyLayout title="About — Destiny-Ghost" heading="ABOUT" backHref="/">

  <!-- App Description -->
  <section class="space-y-5">
    <h1 class="text-medium font-medium tracking-[0.3em] text-white uppercase">What is Destiny-Ghost</h1>
    <p class="text-base sm:text-lg md:text-xl font-light leading-relaxed tracking-wide text-white/90">
      Destiny-Ghost is an SMS interface for Destiny players. Text a weapon name and get stats back instantly. Receive alerts when Xur arrives or vendor inventory resets. Your Ghost, in your pocket.
    </p>
    <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/50">
      Not affiliated with, maintained, or endorsed by Bungie.
    </p>
  </section>

  <div class="h-px w-full bg-white/10"></div>

  <!-- SMS Program Terms -->
  <section class="space-y-12">
    <h2 class="text-medium font-medium tracking-[0.3em] text-white uppercase">SMS Program Terms</h2>

    <div class="space-y-10">

      <div class="space-y-2">
        <p class="text-sm tracking-[0.25em] text-white uppercase">Program</p>
        <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/80">
          Destiny-Ghost sends SMS and MMS notifications and search results to Destiny players who have opted in. Messages include weapon lookup results, vendor sale alerts, and weekly reset notifications.
        </p>
      </div>

      <div class="space-y-2">
        <p class="text-sm tracking-[0.25em] text-white uppercase">Opt-In</p>
        <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/80">
          By providing your mobile phone number and checking the consent box during registration, you agree to receive SMS and MMS messages from Destiny-Ghost. The consent checkbox is unchecked by default and is separate from any other agreements. Consent is not required to access the service.
        </p>
      </div>

      <div class="space-y-2">
        <p class="text-sm tracking-[0.25em] text-white uppercase">Opt-In Confirmation</p>
        <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/80">
          Upon enrollment you will receive a confirmation message:
        </p>
        <p class="mt-3 border border-white/10 bg-white/5 px-4 py-3 font-mono text-xs leading-relaxed text-white/70">
          Welcome to Destiny-Ghost! Message frequency varies. Msg &amp; data rates may apply. Reply HELP for help, STOP to cancel.
        </p>
      </div>

      <div class="space-y-2">
        <p class="text-sm tracking-[0.25em] text-white uppercase">Message Frequency</p>
        <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/80">
          Message frequency varies. Vendor and Xur alerts are sent on their respective reset schedules. Weapon search responses are sent on demand.
        </p>
      </div>

      <div class="space-y-2">
        <p class="text-sm tracking-[0.25em] text-white uppercase">Rates</p>
        <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/80">
          Message and data rates may apply.
        </p>
      </div>

      <div class="space-y-2">
        <p class="text-sm tracking-[0.25em] text-white uppercase">Opt-Out</p>
        <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/80">
          Reply <strong>STOP</strong> at any time to unsubscribe from Destiny-Ghost. No further messages will be sent. Reply <strong>START</strong> or <strong>UNSTOP</strong> to re-subscribe.
        </p>
      </div>

      <div class="space-y-2">
        <p class="text-sm tracking-[0.25em] text-white uppercase">Help</p>
        <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/80">
          Reply <strong>HELP</strong> for assistance. You can also contact support at <a href={`mailto:${SUPPORT_EMAIL}`} class="text-white/70 underline underline-offset-4 hover:text-white transition-colors">{SUPPORT_EMAIL}</a>.
        </p>
      </div>

      <div class="space-y-2">
        <p class="text-sm tracking-[0.25em] text-white uppercase">Carrier Disclaimer</p>
        <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/80">
          Carriers are not liable for any delayed or undelivered messages.
        </p>
      </div>

      <div class="space-y-2">
        <p class="text-sm tracking-[0.25em] text-white uppercase">Privacy & Data</p>
        <p class="text-sm sm:text-base font-light leading-relaxed tracking-wide text-white/80">
          Your mobile number and messaging consent are used solely to deliver Destiny-Ghost notifications and search results. Text messaging originator opt-in data and consent will not be shared with, sold to, or bought by any third parties or affiliates for marketing or promotional purposes.
          View our <a href="/privacy" class="text-white/70 underline underline-offset-4 hover:text-white transition-colors">Privacy Policy</a> and <a href="/terms" class="text-white/70 underline underline-offset-4 hover:text-white transition-colors">Terms of Service</a>.
        </p>
      </div>

    </div>
  </section>

</PolicyLayout>
