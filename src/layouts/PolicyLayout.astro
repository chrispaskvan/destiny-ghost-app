---
import BaseLayout from './BaseLayout.astro';
import GhostLogo from '../components/GhostLogo.jsx';

const { title, heading, backHref = '/' } = Astro.props;
---

<BaseLayout title={title}>
  <div class="relative flex min-h-screen w-full flex-col bg-obsidian text-white selection:bg-white/80 selection:text-black">

    <header class="relative z-10 flex w-full items-center justify-between px-6 py-6 md:px-8 md:py-8">
      <a href="/" class="group flex size-12 shrink-0 items-center justify-center rounded-full transition-colors hover:bg-transparent active:scale-95">
        <GhostLogo className="text-white opacity-80 transition-opacity group-hover:opacity-100" />
      </a>
      <p class="shrink-0 text-xs font-medium tracking-[0.3em] text-white opacity-60">{heading}</p>
    </header>

    <main class="mx-auto w-full max-w-4xl flex flex-1 flex-col gap-12 px-6 pb-16 pt-10 sm:gap-14 sm:px-10 sm:pt-14 md:gap-16 md:px-16 md:pt-20 lg:px-20 lg:pt-24">

      <slot />

      <a
        href={backHref}
        class="group flex items-center justify-start gap-2 text-sm font-medium tracking-[0.1em] text-white/50 transition-all hover:text-white focus:outline-none"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 -960 960 960"
          width="16"
          height="16"
          fill="currentColor"
          class="transition-transform group-hover:-translate-x-1"
          aria-hidden="true"
        >
          <path d="m313-440 224 224-57 56-320-320 320-320 57 56-224 224h487v80H313Z" />
        </svg>
        <span class="relative">
          Back
          <span class="absolute -bottom-1 left-0 h-px w-0 bg-white transition-all duration-300 group-hover:w-full"></span>
        </span>
      </a>

    </main>

    <div class="h-8 w-full shrink-0"></div>
  </div>
</BaseLayout>
